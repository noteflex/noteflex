# ═══════════════════════════════════════════════════
# Noteflex .gitignore
# ═══════════════════════════════════════════════════

# ── Dependencies ────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ────────────────────────────────────
dist/
dist-ssr/
build/
.vite/

# ── TypeScript incremental build cache ──────────────
*.tsbuildinfo

# ── Environment files (민감 정보!) ──────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.env.staging
.env.local.test
!.env.example
!.env.sample

# ── Logs ────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor / IDE ────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursorignore
.history/

# ── OS ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Supabase ───────────────────────────────────────
supabase/.branches
supabase/.temp
.supabase/

# ── Testing / Coverage ──────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Misc ────────────────────────────────────────────
*.local
.cache/
.parcel-cache/
.turbo/
.tmp/

# ── Simulator logs (§4 Step B) ──────────────────────
tmp/sim-logs/

# ── notegen-sim 결과 (5단계, 시나리오당 ~5MB) ────────
test-results/

# ── Claude Code local settings ──────────────────────
.claude/settings.local.json
