# ── Supabase ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Paddle ─────────────────────────────────────────────────────
# 출시 직전: sandbox → production, test_ → live_ 로 교체
VITE_PADDLE_ENVIRONMENT=sandbox
VITE_PADDLE_CLIENT_TOKEN=test_xxx
VITE_PADDLE_PRICE_MONTHLY=pri_xxx
VITE_PADDLE_PRICE_YEARLY=pri_xxx

# ── Feature flags ──────────────────────────────────────────────
# 로컬 개발: .env.local 에서 VITE_GAME_ENABLED=true 설정
# VITE_GAME_ENABLED=false

# ── Google AdSense ──────────────────────────────────────────────
# 출시 직전 실제 값으로 교체 (심사 승인 후)
VITE_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# 광고 슬롯 ID (AdSense 대시보드에서 각 광고 단위별 발급) — 10개 위치별 ad unit
VITE_ADSENSE_SLOT_PLAY_BOTTOM=0000000000
VITE_ADSENSE_SLOT_BLOG_LIST_LEFT=0000000001
VITE_ADSENSE_SLOT_BLOG_LIST_RIGHT=0000000002
VITE_ADSENSE_SLOT_BLOG_LIST_INFEED=0000000003
VITE_ADSENSE_SLOT_BLOG_LIST_MOBILE=0000000004
VITE_ADSENSE_SLOT_BLOG_POST_LEFT=0000000005
VITE_ADSENSE_SLOT_BLOG_POST_RIGHT=0000000006
VITE_ADSENSE_SLOT_BLOG_POST_MOBILE=0000000007
VITE_ADSENSE_SLOT_DASH_INFEED=0000000008
VITE_ADSENSE_SLOT_DASH_BOTTOM=0000000009
VITE_ADSENSE_SLOT_BLOG_POST_BOTTOM=0000000010
VITE_ADSENSE_SLOT_PLAY_MID=0000000011

# 출시 직전 true 로 변경 (사업자 등록 + AdSense 심사 승인 후)
VITE_ADS_ENABLED=false
# in-feed 광고 비상 스위치 (심사 reject 시 false 로 즉시 비활성화)
VITE_INFEED_ADS_ENABLED=false

# ── Sentry ─────────────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
