--    AND column_name IN ('note_key','octave','clef')
--  ORDER BY ordinal_position;
--
-- 기대값:
--   note_key | text
--   octave   | integer
--   clef     | text
--
-- 비교:
-- SELECT column_name, data_type
--   FROM information_schema.columns
--  WHERE table_schema='public' AND table_name='user_note_logs'
--    AND column_name IN ('note_key','octave','clef')
